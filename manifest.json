{
  "manifest_version": 3,
  "name": "Browserx: General AI Agent For Work Tasks Automation",
  "version": "0.0.5",
  "description": "Privacy Preserving And Open Source AI agent With Browser Automation Capabilities",
  "permissions": [
    "tabs",
    "tabGroups",
    "windows",
    "activeTab",
    "storage",
    "scripting",
    "webNavigation",
    "sidePanel",
    "contextMenus",
    "alarms",
    "debugger",
    "downloads"
  ],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [{
    "resources": ["prompts/agent_prompt.md", "prompts/user_instruction.md", "*.map", "content.js.map"],
    "matches": ["<all_urls>"]
  }],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Browserx Agent",
    "default_icon": {
      "16": "static/logo_png_no_word_round_128_w_dev.png",
      "48": "static/logo_png_no_word_round_128_w_dev.png",
      "128": "static/logo_png_no_word_round_128_w_dev.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "all_frames": false,
    "run_at": "document_idle"
  }],
  "icons": {
    "16": "static/logo_png_no_word_round_128_w_dev.png",
    "48": "static/logo_png_no_word_round_128_w_dev.png",
    "128": "static/logo_png_no_word_round_128_w_dev.png"
  },
  "commands": {
    "toggle-sidepanel": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Toggle Browserx side panel"
    },
    "quick-action": {
      "suggested_key": {
        "default": "Alt+Shift+Q"
      },
      "description": "Quick action on current page"
    }
  }
}
