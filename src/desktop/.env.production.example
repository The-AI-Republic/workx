# WorkX Desktop — PRODUCTION environment reference
#
# This is the canonical, complete variable set for a production desktop build.
# It is a REFERENCE ONLY — the real src/desktop/.env is:
#   - generated by CI from GitHub Actions `vars` at release time
#     (see the "Create desktop .env" step in .github/workflows/release.yml), and
#   - gitignored locally (copy this file to src/desktop/.env for a local prod build).
#
# Keep this file in sync with the release.yml heredoc.
#
# Environment-specific values (hostnames, OIDC client id, cookie domain) are the
# ONLY things that differ between test and prod — in CI they come from Actions
# `vars` with the prod defaults shown here. Everything else is structural and
# identical across environments.
#
# BEFORE the first production release:
#   1. Confirm the hostnames below are the real prod endpoints.
#   2. Register the prod OIDC client `workx-desktop` in the home-page IdP with
#      redirect `workx://auth/callback` and require_pkce = true.
#   3. Ensure the prod gateway has JWT auth enabled (GATEWAY_JWT_AUTH_ENABLED)
#      with JWKS/issuer/audience svc:hub + the three spend caps configured.

# --- Home-page auth / backend (environment-specific) ---
VITE_AUTH_COOKIE_DOMAIN=.airepublic.com
VITE_AUTH_BASE_URL=https://home.airepublic.com
VITE_BACKEND_API_BASE_URL=https://api.airepublic.com
VITE_AUTH_ACCESS_COOKIE_NAME=ai_access
VITE_AUTH_REFRESH_COOKIE_NAME=ai_refresh
VITE_AUTH_CSRF_COOKIE_NAME=ai_csrf
VITE_AUTH_STATUS_COOKIE_NAME=ai_auth_status
VITE_AUTH_USER_NAME_COOKIE_NAME=ai_user_name
VITE_AUTH_USER_EMAIL_COOKIE_NAME=ai_user_email
VITE_AUTH_LOGIN_PATH=/login
VITE_AUTH_DESKTOP_SESSION_PATH=/auth/desktop/session
VITE_AUTH_DESKTOP_REFRESH_PATH=/auth/desktop/refresh
VITE_AUTH_PROFILE_PATH=/api/v1/users/profile
VITE_AUTH_USER_CENTER_PATH=/user-center/info
VITE_AUTH_PRICING_PATH=/pricing

# --- AI Hub gateway routing (LLM -> {gateway}/v1, MCP -> {gateway}/mcp) ---
VITE_LLM_ROUTING_MODE=gateway
VITE_GATEWAY_BASE_URL=https://gateway.airepublic.com
VITE_GATEWAY_CATALOG_URL=https://hub.airepublic.com/apps
VITE_GATEWAY_MCP_NAME=openhub
VITE_GATEWAY_MCP_AUTH_MODE=session-jwt
VITE_GATEWAY_MCP_TOOL_DISCOVERY=flat

# --- OIDC Auth-Code + PKCE login (svc:hub audience) ---
VITE_AUTH_OIDC_ENABLED=true
VITE_AUTH_OIDC_CLIENT_ID=workx-desktop
VITE_AUTH_OIDC_SCOPES=openid profile email chat apps models offline_access

# --- Runtime-side mirror (Node/Tauri sidecar reads WORKX_*) ---
WORKX_AUTH_BASE_URL=https://home.airepublic.com
WORKX_BACKEND_API_BASE_URL=https://api.airepublic.com
WORKX_AUTH_DESKTOP_SESSION_PATH=/auth/desktop/session
WORKX_AUTH_DESKTOP_REFRESH_PATH=/auth/desktop/refresh
WORKX_AUTH_PROFILE_PATH=/api/v1/users/profile
WORKX_LLM_ROUTING_MODE=gateway
WORKX_GATEWAY_BASE_URL=https://gateway.airepublic.com
WORKX_GATEWAY_CATALOG_URL=https://hub.airepublic.com/apps
WORKX_GATEWAY_MCP_NAME=openhub
WORKX_GATEWAY_MCP_AUTH_MODE=session-jwt
WORKX_GATEWAY_MCP_TOOL_DISCOVERY_HEADER=X-Air-Tool-Discovery
WORKX_GATEWAY_MCP_TOOL_DISCOVERY=flat
WORKX_AUTH_OIDC_ENABLED=true
WORKX_AUTH_OIDC_CLIENT_ID=workx-desktop
WORKX_AUTH_OIDC_SCOPES=openid profile email chat apps models offline_access
