{
  "manifest_version": 3,
  "name": "__MSG_extension_name__",
  "version": "0.0.36",
  "description": "__MSG_extension_description__",
  "default_locale": "en",
  "managed_storage": "managed-schema.json",
  "permissions": [
    "tabs",
    "tabGroups",
    "windows",
    "activeTab",
    "storage",
    "scripting",
    "webNavigation",
    "sidePanel",
    "contextMenus",
    "alarms",
    "debugger",
    "downloads",
    "cookies",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "prompts/default_workx_agent_prompt.md",
        "prompts/user_instruction.md",
        "*.map",
        "content.js.map"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "WorkX Agent",
    "default_icon": {
      "16": "static/AI RepublicLOGO01.png",
      "48": "static/AI RepublicLOGO01.png",
      "128": "static/AI RepublicLOGO01.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": false,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "static/AI RepublicLOGO01.png",
    "48": "static/AI RepublicLOGO01.png",
    "128": "static/AI RepublicLOGO01.png"
  },
  "commands": {
    "toggle-sidepanel": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Toggle WorkX side panel"
    },
    "quick-action": {
      "suggested_key": {
        "default": "Alt+Shift+Q"
      },
      "description": "Quick action on current page"
    }
  }
}
