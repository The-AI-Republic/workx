{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorkX",
  "mainBinaryName": "WorkX",
  "version": "../package.json",
  "identifier": "com.airepublic.workx",
  "build": {
    "beforeBuildCommand": { "script": "npm run build:desktop && npm run build:desktop-runtime-sidecar && npm run build:sidecar && npm run build:ripgrep-sidecar", "cwd": ".." },
    "beforeDevCommand": { "script": "npm run build:desktop-runtime-sidecar && npm run build:sidecar && npm run build:ripgrep-sidecar && npm run dev:desktop", "cwd": ".." },
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist/desktop"
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "externalBin": ["binaries/chrome-devtools-mcp", "binaries/rg"],
    "resources": {
      "sidecar/desktop-runtime": "desktop-runtime"
    },
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "longDescription": "WorkX - AI-powered personal assistant agent",
    "shortDescription": "WorkX - Personal Assistant",
    "createUpdaterArtifacts": true,
    "targets": "all",
    "linux": {
      "deb": {
        "depends": [],
        "desktopTemplate": "templates/linux-desktop.desktop"
      },
      "rpm": {
        "desktopTemplate": "templates/linux-desktop.desktop"
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 700,
        "resizable": true,
        "title": "WorkX",
        "width": 1000,
        "visible": true
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwNEQyMTEzQzc3OTI0MzEKUldReEpIbkhFeUZOVUZBa01rK0s1RVlvYXVFc0EzNExaK2loUFhhbVR3TGszUUwvcFBkRG84V1cK",
      "endpoints": [
        "https://workx-desktop-releases.s3.us-west-2.amazonaws.com/{{target}}-{{arch}}/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "applepi",
          "workx"
        ]
      }
    }
  }
}
