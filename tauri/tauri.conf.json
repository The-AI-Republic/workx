{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Apple Pi",
  "version": "0.1.0",
  "identifier": "com.airepublic.pi",
  "build": {
    "beforeBuildCommand": "npm run build:desktop",
    "beforeDevCommand": "npm run dev:desktop",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist/desktop"
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "longDescription": "Pi - AI-powered personal assistant agent",
    "shortDescription": "Pi - Personal Assistant",
    "createUpdaterArtifacts": true,
    "targets": "all",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 700,
        "resizable": true,
        "title": "Apple Pi",
        "width": 1000,
        "visible": true
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGOTlGNDVFNTg1QTMxNzMKUldSek1WcFlYdlNaLzZ6cUR2aXdqRTM2dHpTMGtwTzh2S1MyWUdXVHFpNG1YYjJqdkFWRlYzUjAK",
      "endpoints": [
        "https://github.com/The-AI-Republic/browserx/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "airepublic-pi"
        ]
      }
    }
  }
}
