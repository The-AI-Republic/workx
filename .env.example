# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Base URL for OpenAI API (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model configuration
# OPENAI_MODEL=gpt-4

# Optional: Request timeout in milliseconds (default: 30000)
# OPENAI_TIMEOUT=30000

# Backend API Configuration (optional - for AI Republic backend routing)
# VITE_HOME_PAGE_BASE_URL=https://airepublic.com
# VITE_BACKEND_API_BASE_URL=
# VITE_COOKIE_DOMAIN=.airepublic.com
# VITE_LOGIN_PAGE=https://airepublic.com/login

# i18n Translation Script (only needed for running translate-i18n.js)
# FIREWORKS_API_KEY=your_fireworks_api_key_here
