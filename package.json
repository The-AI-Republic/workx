{
  "name": "pi",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "node scripts/check-env.js extension && vite",
    "dev:desktop": "node scripts/check-env.js desktop && vite --config vite.config.desktop.mts --port 5174",
    "tauri:dev": "node scripts/check-env.js desktop && rm -rf dist/desktop && cd tauri && env -u GTK_PATH -u GTK_EXE_PREFIX -u SNAP_LIBRARY_PATH -u GIO_MODULE_DIR -u GTK_IM_MODULE_FILE -u GDK_PIXBUF_MODULE_FILE -u GDK_PIXBUF_MODULEDIR -u GSETTINGS_SCHEMA_DIR -u LOCPATH cargo tauri dev",
    "tauri:build": "node scripts/check-env.js desktop && npm run build:sidecar && cd tauri && cargo tauri build",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "vite:build": "vite build",
    "build": "node scripts/check-env.js extension && node scripts/build.js",
    "build:desktop": "node scripts/check-env.js desktop && vite build --config vite.config.desktop.mts",
    "extract-i18n": "node scripts/extract-i18n.js",
    "translate": "node scripts/translate-i18n.js",
    "translate-validate": "node scripts/translate-i18n.js validate",
    "build:watch": "vite build --watch",
    "build:testtool": "vite build --config tests/tools/e2e/vite.config.ts",
    "test": "bash tauri/scripts/test-rust.sh && vitest",
    "test:rust": "bash tauri/scripts/test-rust.sh",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.{ts,svelte,html,css}'"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "description": "",
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/svelte": "^5.2.8",
    "@types/chrome": "^0.1.12",
    "@types/marked": "^5.0.2",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitest/ui": "^3.2.4",
    "@yao-pkg/pkg": "^5.16.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.21",
    "chrome-mock": "^0.0.9",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.12.4",
    "fake-indexeddb": "^6.2.2",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "svelte": "^4.2.20",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^5.4.20",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "@google/genai": "^1.30.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-deep-link": "^2.4.7",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2",
    "@types/eventsource": "^1.1.15",
    "chrome-devtools-mcp": "^0.17.0",
    "dom-accessibility-api": "^0.7.0",
    "eventsource": "^2.0.2",
    "fuse.js": "^7.1.0",
    "marked": "^17.0.0",
    "openai": "^6.6.0",
    "svelte-spa-router": "^4.0.1",
    "tippy.js": "^6.3.7",
    "uuid": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^3.23.8"
  }
}
